SERVER_PORT=8080

# PostgreSQL (local Docker Compose)
DB_URL=jdbc:postgresql://localhost:5432/ai_analytics
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DRIVER=org.postgresql.Driver

# Render provides DATABASE_URL as postgres:// — convert to JDBC:
# DB_URL=jdbc:postgresql://HOST:5432/ai_analytics

JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
H2_CONSOLE_ENABLED=false

PYTHON_ENGINE_URL=http://localhost:8000

# OpenRouter AI — set your key here (never commit real keys)
AI_PROVIDER_URL=https://openrouter.ai/api/v1/chat/completions
AI_PROVIDER_MODEL=openai/gpt-4o-mini
AI_PROVIDER_KEY=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_SECRET=change-me-to-a-long-random-secret-key-at-least-32-chars
JWT_EXPIRATION_MS=86400000
STORAGE_UPLOAD_DIR=uploads
APP_LOG_LEVEL=INFO
